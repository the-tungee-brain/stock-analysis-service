{
  "id": "dividend_stock",
  "label": "Dividend Stocks (Quality/Growth)",
  "description": "High-quality dividend stocks with sustainable payouts and growth.",
  "equity_query": {
    "operator": "and",
    "clauses": [
      {"op": "is-in", "field": "exchange", "values": ["NMS", "NYQ"]},
      {"op": "eq", "field": "region", "value": "us"},
      {"op": "gte", "field": "marketCap", "value": 2000000000},
      {"op": "gte", "field": "dividendYield", "value": 0.02},
      {"op": "lte", "field": "dividendYield", "value": 0.08},
      {"op": "lte", "field": "trailingPE", "value": 25},
      {
        "op": "is-in",
        "field": "sector",
        "values": [
          "Consumer Defensive",
          "Healthcare",
          "Financial Services",
          "Industrials",
          "Utilities",
          "Energy",
          "Real Estate"
        ]
      }
    ]
  },
  "post_filters": {
    "dividend_quality": {
      "min_years_dividend_growth": 5,
      "max_payout_ratio": 0.60,
      "min_dividend_cagr_5y": 0.05
    },
    "balance_sheet": {
      "max_debt_to_equity": 2.0,
      "min_interest_coverage": 3.0
    }
  }
}
